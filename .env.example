# OpenAI (verdict + appeal generation)
OPENAI_API_KEY=
# Optional — defaults to gpt-4.1-nano (cheapest available on many accounts)
OPENAI_MODEL_ID=gpt-4.1-nano

# Optional: absolute base URL used in shareable packages (defaults to request origin)
NEXT_PUBLIC_APP_URL=

# Convex (filled by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# ---- Monad testnet (on-chain court record) ----
# Server wallet that signs verdict seals. Generate with `npm run chain:wallet`,
# fund at https://faucet.monad.xyz. Set BOTH on the Convex deployment
# (npx convex env set), not just locally.
MONAD_JUDGE_PRIVATE_KEY=
# BeefVerdictRegistry address, printed by `npm run chain:deploy`
MONAD_REGISTRY_ADDRESS=
# Optional RPC override (defaults to https://testnet-rpc.monad.xyz)
MONAD_RPC_URL=

# Report form → Gmail (optional). Create an App Password at:
# https://myaccount.google.com/apppasswords
# Then reports also land in barsbuildme@gmail.com.
REPORT_EMAIL_USER=barsbuildme@gmail.com
REPORT_EMAIL_PASS=
